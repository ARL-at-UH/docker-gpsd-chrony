# Normalize line endings: store as LF in the repo, detect text automatically
* text=auto

# Files executed or parsed inside the Linux container must check out as LF,
# even on Windows — CRLF breaks the bash shebang and config parsing
*.sh text eol=lf
*.conf text eol=lf
*.env text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.dts text eol=lf
Dockerfile text eol=lf
