# udev rule: stable device name for the USB GNSS receiver
#
# Creates /dev/gps0 as a symlink to whatever /dev/ttyACM* the receiver
# enumerates as, so the name survives reboots, replugs, and multi-device
# enumeration order changes.
#
# Install: see README.md in this directory.
# Discover your receiver's attributes with:
#   udevadm info -a -n /dev/ttyACM0 | grep -iE 'idVendor|idProduct|serial'

# u-blox GNSS receiver (ZED-F9P and most other u-blox modules: VID 1546)
SUBSYSTEM=="tty", ATTRS{idVendor}=="1546", ATTRS{idProduct}=="01a9", SYMLINK+="gps0", MODE="0660"

# --- Variants (uncomment and edit as needed) ---

# Generic template for any other receiver — fill in your VID/PID:
#SUBSYSTEM=="tty", ATTRS{idVendor}=="XXXX", ATTRS{idProduct}=="YYYY", SYMLINK+="gps0", MODE="0660"

# Multiple identical receivers — disambiguate by USB serial number:
#SUBSYSTEM=="tty", ATTRS{idVendor}=="1546", ATTRS{idProduct}=="01a9", ATTRS{serial}=="ABC123", SYMLINK+="gps0", MODE="0660"

# Receivers without a unique serial — pin to the physical USB port instead
# (KERNELS is the port path; find it in the udevadm info -a output, e.g. "1-1.3"):
#SUBSYSTEM=="tty", KERNELS=="1-1.3", ATTRS{idVendor}=="1546", SYMLINK+="gps0", MODE="0660"
