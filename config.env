### GPSD and CHRONY ###
# GPS Configuration
## apalis
# GPS_DEVICE=/dev/apalis-uart2
# PPS_DEVICE=/dev/pps1
## pi
#GPS_DEVICE=/dev/ttyAMA0
#PPS_DEVICE=/dev/pps0
#GPS_SPEED=38400

#mallow
GPS_DEVICE=/dev/ttyACM0
PPS_DEVICE=/dev/pps0
GPS_SPEED=115200

DEBUG_LEVEL=1

# GPSD Configuration
GPSD_EXECUTABLE=gpsd
GPSD_SOCKET=/var/run/gpsd.sock
GPSD_LISTEN_ALL=true
GPSD_NO_WAIT=true
GPSD_PID_FILE=/var/run/gpsd.pid

# Chronyd Configuration
CHRONYD_EXECUTABLE=/usr/sbin/chronyd
CHRONYD_USER=chrony
CHRONYD_FOREGROUND=true
ENABLE_SYSCLK=true
LOG_LEVEL=0
CHRONYD_PID_FILE=/var/run/chronyd.pid
CHRONYD_RUN_DIR=/run/chrony
CHRONYD_VAR_DIR=/var/lib/chrony

# Timing Configuration
CHRONYD_START_DELAY=2
GPSD_START_DELAY=10
MONITOR_INTERVAL=5

# Monitoring Configuration
ENABLE_MONITORING=true
RESTART_ON_FAILURE=false