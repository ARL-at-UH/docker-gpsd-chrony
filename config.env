### GPSD and CHRONY ###
# GPS Configuration
#
# GPS_DEVICE and PPS_DEVICE are container-side paths, fixed by the
# devices: mapping in compose.yaml (host name on the left, container name
# on the right). Platform differences belong on the host side of that
# mapping, e.g.:
#   pi:     - /dev/ttyAMA0:/dev/gps0       - /dev/pps0:/dev/pps0
#   apalis: - /dev/apalis-uart2:/dev/gps0  - /dev/pps1:/dev/pps0
#   mallow: - /dev/ttyACM0:/dev/gps0       - /dev/pps0:/dev/pps0
#           (or - /dev/gps0:/dev/gps0 with the udev_rules/ symlink)
# These two values normally never change:
GPS_DEVICE=/dev/gps0
PPS_DEVICE=/dev/pps0

# Serial baud rate — match your receiver/UART (ignored for USB CDC-ACM receivers)
GPS_SPEED=38400

DEBUG_LEVEL=1

# GPSD Configuration
GPSD_EXECUTABLE=gpsd
GPSD_SOCKET=/var/run/gpsd.sock
GPSD_LISTEN_ALL=true
GPSD_NO_WAIT=true
GPSD_PID_FILE=/var/run/gpsd.pid

# Chronyd Configuration
CHRONYD_EXECUTABLE=/usr/sbin/chronyd
CHRONYD_USER=chrony
CHRONYD_FOREGROUND=true
ENABLE_SYSCLK=true
LOG_LEVEL=0
CHRONYD_PID_FILE=/var/run/chronyd.pid
CHRONYD_RUN_DIR=/run/chrony
CHRONYD_VAR_DIR=/var/lib/chrony

# Timing Configuration
CHRONYD_START_DELAY=2
GPSD_START_DELAY=10
MONITOR_INTERVAL=5

# Monitoring Configuration
ENABLE_MONITORING=true
RESTART_ON_FAILURE=true